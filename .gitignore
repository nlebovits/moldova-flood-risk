# ===========================================
# Licensed brand fonts — DO NOT COMMIT
# Per README: Vert Grotesk Display, Neue Swiss, Berkeley Mono are licensed
# and must not be committed to a public-capable repo. The app uses
# Fraunces + Inter web fallbacks declared in colors_and_type.css until
# fonts are dropped in locally by a licensed dev.
# ===========================================
design-reference/fonts/*
!design-reference/fonts/.gitkeep

# ===========================================
# Node / Vite (app/)
# ===========================================
app/node_modules/
app/dist/
app/.vite/
app/*.local
app/.env
app/.env.local
app/.env.*.local
app/.vercel/
app/coverage/

# ===========================================
# Python / uv (precompute/)
# ===========================================
precompute/.venv/
precompute/__pycache__/
precompute/**/__pycache__/
precompute/*.pyc
precompute/.ipynb_checkpoints/
precompute/.pytest_cache/

# ===========================================
# Precompute build artifacts — large, regenerable.
# The small JSON sidecars (summary.json, admin.geojson, eal.json) land in
# app/public/data/ and ARE committed so deploys don't need a precompute step.
# The large artifacts — field_attrs.json and fields.pmtiles — are NOT committed
# (they blow past GitHub's 100 MB limit). fields.pmtiles is range-requested, so
# in production it is hosted on object storage (Source Cooperative / a CDN) and
# FIELDS_PMTILES in app/src/map/sources.ts points at that URL. For local dev it
# sits at app/public/data/fields.pmtiles (regenerate: `make fields-tiles`).
# ===========================================
precompute/_cache/
precompute/_work/
precompute/*.tif
precompute/*.tiff

# ===========================================
# Editor / OS
# ===========================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# ===========================================
# Logs
# ===========================================
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===========================================
# code-review-graph (kept; tracks code, not data)
# ===========================================
# (intentionally NOT ignored — graph.db helps reviewers)

# Generated data (regenerate with: make data)
app/public/data/field_attrs.json
# Per-RP flood-depth COGs (~25 MB total). Range-requested by deck.gl; for
# production host on object storage and point JRC_COG_BASE in sources.ts there.
app/public/data/jrc/
app/public/data/fields.pmtiles
report/data/field_attrs.json
report/.jupyter_cache/
.vercel
