# Only app/ + i18n/ are needed to build the static site. Everything below is
# either huge regenerable data (now hosted on Source Cooperative), the offline
# precompute pipeline, or private assets — none belong in the deploy upload.
**/node_modules
precompute
report
design-reference
app/dist

# Large data artifacts — served from Source Cooperative at runtime, not bundled.
app/public/data/field_attrs.json
app/public/data/fields.pmtiles
app/public/data/jrc

# Licensed fonts are symlinks into design-reference/fonts/ (gitignored, must
# stay private). On a fresh checkout those symlinks dangle and Rolldown errors
# reading them. Excluding the dir lets the build treat /fonts/* as runtime URLs
# and fall back to the Fraunces/Inter web fonts (imported in tokens.css).
app/public/fonts
